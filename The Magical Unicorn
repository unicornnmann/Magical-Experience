                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    Parent = stat_card
                })
                
                task.spawn(function()
                    local success, username = pcall(function()
                        return Players:GetNameFromUserIdAsync(stat.id)
