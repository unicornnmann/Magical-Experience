	function whoosh(vroom)
		vroom.Parent = workspace
		vroom.Name = "Projectile"
		vroom.CFrame = CFrame.new(char.Head.CFrame.p,mouse.Hit.p)*CFrame.Angles(math.rad(0),math.rad(90),math.rad(0))
