    elseif inputState == Enum.UserInputState.End then
        if inputObject.UserInputType == Enum.UserInputType.Keyboard then
            local k = inputObject.KeyCode
            if k == Enum.KeyCode.A or k == Enum.KeyCode.D then steer = 0 end
