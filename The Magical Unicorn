                    if not State.stats_apply_cooldown then
                        tween(quick_apply_btn, { BackgroundColor3 = C.accent }, 0.15)
                    end
                end)
            end
        end
    end
    
    E.update_stats_ui = update_stats_ui
    update_stats_ui()

