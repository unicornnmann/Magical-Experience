                    gradient.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, style.bg),
                        ColorSequenceKeypoint.new(1, style.glow)
                    })
                    gradient.Rotation = 45
                    gradient.Parent = rank_badge
                    
