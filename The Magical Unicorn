local function UpdateDrag(input, frame)
    local CBaseX = DragSettings.InitialPosition.X.Scale * frame.Parent.AbsoluteSize.X + DragSettings.InitialPosition.X.Offset
    local CBaseY = DragSettings.InitialPosition.Y.Scale * frame.Parent.AbsoluteSize.Y + DragSettings.InitialPosition.Y.Offset

    local UpdateCenterX = CBaseX + (input.Position.X - DragSettings.Start.X)
    local UpdateCenterY = CBaseY + (input.Position.Y - DragSettings.Start.Y)

    UpdateCenterX = math.clamp(UpdateCenterX, frame.AbsoluteSize.X / 2, frame.Parent.AbsoluteSize.X - frame.AbsoluteSize.X / 2)
    UpdateCenterY = math.clamp(UpdateCenterY, frame.AbsoluteSize.Y / 2 - 60, frame.Parent.AbsoluteSize.Y - frame.AbsoluteSize.Y / 2)

    TweenService:Create(frame, TweenInfo.new(DragSettings.Speed), {Position = UDim2.new(0, UpdateCenterX, 0, UpdateCenterY)}):Play()
end

