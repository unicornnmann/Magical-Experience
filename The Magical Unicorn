    z = z:gsub("^DFInt", "")
    z = z:gsub("^DFFlag", "")
    z = z:gsub("^FFlag", "")
    z = z:gsub("^FInt", "")
    z = z:gsub("FString", "")
    z = z:gsub("FLog", "")
    return z
end

