local flyKeyDown, flyKeyUp
local FlyConn, CharConn
local FlyBV, FlyBG
local CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
local lCONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
local SPEED = 0

local function startFly(Char)
    local Humanoid = Char:WaitForChild("Humanoid")
    local HRP = Char:WaitForChild("HumanoidRootPart")
    FlyBG = Instance.new("BodyGyro")
    FlyBG.P = 9e4
    FlyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    FlyBG.CFrame = HRP.CFrame
    FlyBG.Parent = HRP
    FlyBV = Instance.new("BodyVelocity")
    FlyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    FlyBV.Velocity = Vector3.zero
    FlyBV.Parent = HRP
    Humanoid.PlatformStand = true
end

local function stopFly()
    if flyKeyDown then flyKeyDown:Disconnect() flyKeyDown = nil end
    if flyKeyUp then flyKeyUp:Disconnect() flyKeyUp = nil end
    if FlyBG then FlyBG:Destroy() FlyBG = nil end
    if FlyBV then FlyBV:Destroy() FlyBV = nil end
end

function FLY()
    if getgenv().Velocity.Flying.Enabled then return end
    getgenv().Velocity.Flying.Enabled = true
    local function apply(Char)
        startFly(Char)
    end
    if Player.Character then
        apply(Player.Character)
    end
    CharConn = Player.CharacterAdded:Connect(function(Char)
        if getgenv().Velocity.Flying.Enabled then
            task.wait(0.15)
            apply(Char)
        end
    end)
    flyKeyDown = InputService.InputBegan:Connect(function(Input, GP)
        if GP then return end
        if Input.KeyCode == Enum.KeyCode.W then CONTROL.F = getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.S then CONTROL.B = -getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.A then CONTROL.L = -getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.D then CONTROL.R = getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.E then CONTROL.Q = getgenv().Velocity.Flying.Value * 2
        elseif Input.KeyCode == Enum.KeyCode.Q then CONTROL.E = -getgenv().Velocity.Flying.Value * 2 end
    end)
    flyKeyUp = InputService.InputEnded:Connect(function(Input)
        if Input.KeyCode == Enum.KeyCode.W then CONTROL.F = 0
        elseif Input.KeyCode == Enum.KeyCode.S then CONTROL.B = 0
        elseif Input.KeyCode == Enum.KeyCode.A then CONTROL.L = 0
        elseif Input.KeyCode == Enum.KeyCode.D then CONTROL.R = 0
        elseif Input.KeyCode == Enum.KeyCode.E then CONTROL.Q = 0
        elseif Input.KeyCode == Enum.KeyCode.Q then CONTROL.E = 0 end
    end)
    FlyConn = RunService.Stepped:Connect(function()
        if not getgenv().Velocity.Flying.Enabled then return end
        if not FlyBV or not FlyBG then return end
        local Cam = Workspace.CurrentCamera
        if CONTROL.L + CONTROL.R ~= 0 or CONTROL.F + CONTROL.B ~= 0 or CONTROL.Q + CONTROL.E ~= 0 then
            SPEED = 50
        else
            SPEED = 0
        end
        if SPEED ~= 0 then
            FlyBV.Velocity =
                ((Cam.CFrame.LookVector * (CONTROL.F + CONTROL.B)) +
                ((Cam.CFrame * CFrame.new(
                    CONTROL.L + CONTROL.R,
                    (CONTROL.F + CONTROL.B + CONTROL.Q + CONTROL.E) * 0.2,
                    0
                ).p) - Cam.CFrame.p)) * SPEED
            lCONTROL = CONTROL
        else
            FlyBV.Velocity = Vector3.zero
        end
        FlyBG.CFrame = Cam.CFrame
    end)
end

function BreakVelocity()
    pcall(function()
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.Velocity = Vector3.zero
        end
    end)
end

function UNFLY()
    getgenv().Velocity.Flying.Enabled = false
    if FlyConn then FlyConn:Disconnect() FlyConn = nil end
    if CharConn then CharConn:Disconnect() CharConn = nil end
    CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    lCONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    SPEED = 0
    stopFly()
 
    pcall(function()
        if Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") then
            local hum = Player.Character:FindFirstChildOfClass("Humanoid")
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end)
    pcall(function()
        if Player.Character then
            local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local bg = hrp:FindFirstChildOfClass("BodyGyro")
                if bg then bg:Destroy() end
                local bv = hrp:FindFirstChildOfClass("BodyVelocity")
                if bv then bv:Destroy() end
            end
        end
    end)
end

