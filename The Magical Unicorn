                        E.input.Text = id_str
                        State.input_ready = true
                        local was_applied = State.applied_id == stat.id
                        if was_applied then
                            State.applied_id = nil
                        end
                        Av.apply(id_str, nil, false, true)
                        
                        task.delay(0.75, function()
